@model List<MVC_Stanovi.Models.Stan>

<div class="filteridiv">
    <a href="/Home/Index">Logout</a>
    <a href="/Home/Dodavanje" id="dodaj">Dodaj Oglas</a>
</div>

<style>
    #dodaj {
        background-color: gray;
        border-radius: 10px;
        color: white;
        font-size: 12px;
        padding: 10px;
        border: none;
        margin: 10px;
        transition: 0.3s;
    }

        #dodaj:hover {
            box-shadow: 0 0 10px 2px gray;
            cursor: pointer;
            transform: scale(1.05);
        }

    .userglavnidiv {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        padding: 20px;
    }

    .stan {
        border: 1px solid #ccc;
        border-radius: 10px;
        padding: 10px;
        width: 250px;
        text-align: center;
    }

        .stan img {
            width: 100%;
            border-radius: 10px;
        }

        .stan button {
            margin-top: 10px;
        }
</style>

<div class="userglavnidiv">

    @foreach (var s in Model)
    {
        <div class="stan">
            <img src="@s.slika" alt="Stan" />

            <p>
                Lokacija: Zemun Beograd <br />
                Površina: @s.kvadratura m² <br />
                Cena: @s.cena € <br />
                Adresa: @s.ulica
            </p>

            <button>3D pregled</button>
        </div>
    }

</div>