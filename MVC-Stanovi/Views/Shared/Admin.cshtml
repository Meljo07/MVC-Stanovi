<div class="filteridiv">
    <form method="get" action="/Home/Index">
        <select name="tip">
            <option value="">Ulica</option>
            <option value="ulica1">Avijatičarski trg</option>
            <option value="ulica2">Kej oslobođenja</option>
            <option value="ulica3">Karađorđev trg</option>
        </select>

        <select name="kvad">
            <option value="">Kvadratura</option>
            <option value="45">45m²</option>
            <option value="55">55m²</option>
            <option value="65">65m²</option>
            <option value="75">75m²</option>
        </select>

        <select name="cena">
            <option value="">Cena</option>
            <option value="1">100.000 € – 115.000 €</option>
            <option value="2">115.000 € – 130.000 €</option>
            <option value="3">130.000 € – 160.000 €</option>
            <option value="4">160.000 € – 200.000 €</option>
        </select>

        <select name="vrsta">
            <option value="">Vrsta Stana</option>
            <option value="smart">Smart Stan</option>
            <option value="obicni">Običan Stan</option>
        </select>

        <button type="submit">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
        </button>
    </form>
</div>

