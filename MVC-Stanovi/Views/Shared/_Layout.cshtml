<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MVC_Stanovi</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MVC_Stanovi.styles.css" asp-append-version="true" />
</head>
<body>
    <header>

        <div class="div1header">
            <img src="~/slike/ikonica.png" width="50" height="50" />
            <h1> MojStan.rs</h1>
        </div>
        <div class="div2header">
            <ul>
                <li><a asp-action="Home" asp-controller=""> Svi Stanovi </a></li>
                <li><a asp-action="Home" asp-controller=""> Novi Oglasi </a></li>
                <li><a asp-action="Home" asp-controller=""> Lokacije </a></li>
                <li><a asp-action="Home" asp-controller=""> Kontakt </a></li>
            </ul>
        </div>
        <div class="div3header">
            <button> Postavi Oglas </button>
            <button> Uloguj Se </button>
            <button> Registracija </button>
        </div>
    </header>




    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <footer>
        <div class="divfooter">
            <a>  &copy; 2026 - MVC-Stanovi - Privacy </a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
